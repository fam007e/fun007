from keyword import kwlist, softkwlist

def display_keywords() -> None: #1usage
	print('Keywords:')
	for i, kw in enumerate(kwlist, start=1):
		print(f'{i:2}: {kw}')

	print('Soft keywords:')
	for i, skw in enumerate(skwlist, start=1):
		print(f'{i:2}: {skw}')

def main() -> None: #1usage
	display_keywords()


if __name__ == '__main__':
	main()
