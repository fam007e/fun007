#!/data/data/com.termux/files/usr/bin/bash

# ==============================================================================
# Termux Bash Configuration (bashrc_SAFE_TMX) - Modular & Safe Version
# ==============================================================================

# --- Shell Detection & Basic Sourcing ---
[[ $- != *i* ]] && return
[[ -f $PREFIX/bin/fastfetch ]] && fastfetch
[[ -f $PREFIX/etc/bashrc ]] && . $PREFIX/etc/bashrc

if [[ -f $PREFIX/share/bash-completion/bash_completion ]]; then
    . $PREFIX/share/bash-completion/bash_completion
elif [[ -f $PREFIX/etc/bash_completion ]]; then
    . $PREFIX/etc/bash_completion
fi

# --- Section 1: Shell Behavior ---
bind "set bell-style visible"
bind "set completion-ignore-case on"
bind "set show-all-if-ambiguous On"
export HISTFILESIZE=5000
export HISTSIZE=2000
export HISTCONTROL=erasedups:ignoredups:ignorespace
shopt -s histappend checkwinsize
PROMPT_COMMAND='history -a'
stty -ixon

# --- Section 2: Exports ---
export EDITOR=nvim
export VISUAL=nvim
export CLICOLOR=1

# Termux Specifics
alias pbcopy='termux-clipboard-set'
alias pbpaste='termux-clipboard-get'

# --- Section 3: Module - Archive Tools ---
alias mktar='tar -cvf'
alias mkbz2='tar -cvjf'
alias mkgz='tar -cvzf'
alias untar='tar -xvf'
alias unbz2='tar -xvjf'
alias ungz='tar -xvzf'

extract() {
    for archive in "$@"; do
        if [[ -f "$archive" ]]; then
            case "$archive" in
                *.tar.bz2) tar xvjf "$archive" ;;
                *.tar.gz)  tar xvzf "$archive" ;;
                *.zip)     unzip "$archive"    ;;
                *.7z)      7z x "$archive"     ;;
                *) echo "Error: '$archive' format not supported." ;;
            esac
        else
            echo "'$archive' is not a valid file."
        fi
    done
}

# --- Section 4: Module - System Information ---
alias da='date "+%Y-%m-%d %A %T %Z"'
alias h="history | grep "
alias p="ps aux | grep "
alias ff='fastfetch'

distribution() {
    local dtype="unknown"
    [[ -r $PREFIX/etc/os-release ]] && source $PREFIX/etc/os-release && dtype=$ID
    echo "$dtype"
}

# --- Section 5: Module - Development ---
gcom() { git add . && git commit -m "$1"; }
lazyg() { git add . && git commit -m "$1" && git push; }

# --- Section 6: Module - File Utilities ---
alias cp='cp -iv'
alias mv='mv -iv'
alias rm='trash -v' 
alias mkdir='mkdir -p -v'
alias ls='ls -aFh --color=always'
alias ll='ls -alhF'
alias tree='tree -CAhF --dirsfirst'
alias c='clear'
alias x='exit'

# Go up N directories
up() {
    local d=""
    local limit=${1:-1}
    for ((i=0; i<limit; i++)); do d="../$d"; done
    cd "$d"
}

# Safe copy and go
cpg() { cp "$1" "$2" && [[ -d "$2" ]] && cd "$2"; }
mvg() { mv "$1" "$2" && [[ -d "$2" ]] && cd "$2"; }
mkdirg() { mkdir -p "$1" && cd "$1"; }

# --- Section 7: Initializations ---
[[ -x "$(command -v starship)" ]] && eval "$(starship init bash)"
[[ -x "$(command -v zoxide)" ]] && eval "$(zoxide init --cmd cd bash)"

# FZF Bash integration
[[ -f ~/.fzf.bash ]] && . ~/.fzf.bash
