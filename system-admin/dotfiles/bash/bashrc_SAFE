#!/usr/bin/bash

# ==============================================================================
# Desktop Bash Configuration (bashrc_SAFE) - Modular & Safe Version
# ==============================================================================

# --- Shell Detection & Basic Sourcing ---
[[ $- != *i* ]] && return
[[ -f /usr/bin/fastfetch ]] && fastfetch
[[ -f /etc/bashrc ]] && . /etc/bashrc

if [[ -f /usr/share/bash-completion/bash_completion ]]; then
    . /usr/share/bash-completion/bash_completion
elif [[ -f /etc/bash_completion ]]; then
    . /etc/bash_completion
fi

# --- Section 1: Shell Behavior ---
bind "set bell-style visible"
bind "set completion-ignore-case on"
bind "set show-all-if-ambiguous On"
export HISTFILESIZE=10000
export HISTSIZE=5000
export HISTCONTROL=erasedups:ignoredups:ignorespace
shopt -s histappend checkwinsize
PROMPT_COMMAND='history -a'
stty -ixon

# --- Section 2: Exports ---
export EDITOR=nvim
export VISUAL=nvim
export CLICOLOR=1
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# --- Section 3: Module - Archive Tools ---
alias mktar='tar -cvf'
alias mkbz2='tar -cvjf'
alias mkgz='tar -cvzf'
alias untar='tar -xvf'
alias unbz2='tar -xvjf'
alias ungz='tar -xvzf'

extract() {
    for archive in "$@"; do
        if [[ -f "$archive" ]]; then
            case "$archive" in
                *.tar.bz2) tar xvjf "$archive" ;;
                *.tar.gz)  tar xvzf "$archive" ;;
                *.bz2)     bunzip2 "$archive"  ;;
                *.rar)     unrar x "$archive"  ;;
                *.gz)      gunzip "$archive"   ;;
                *.tar)     tar xvf "$archive"  ;;
                *.zip)     unzip "$archive"    ;;
                *.7z)      7z x "$archive"     ;;
                *) echo "Error: '$archive' format not supported." ;;
            esac
        else
            echo "'$archive' is not a valid file."
        fi
    done
}

# --- Section 4: Module - System Information ---
distribution() {
    local dtype="unknown"
    [[ -r /etc/os-release ]] && source /etc/os-release && dtype=$ID
    echo "$dtype"
}

ver() {
    local dtype=$(distribution)
    case "$dtype" in
        arch|debian|ubuntu|fedora) cat /etc/os-release ;;
        *) [[ -s /etc/issue ]] && cat /etc/issue || uname -a ;;
    esac
}

whatsmyip() {
    printf "Internal IP: "
    ip addr show | grep "inet " | grep -v "127.0.0.1" | awk '{print $2}' | cut -d/ -f1
    printf "External IP: "
    curl -s ifconfig.me && echo
}

alias da='date "+%Y-%m-%d %A %T %Z"'
alias diskspace="du -S | sort -n -r | more"
alias mountedinfo='df -hT'

# --- Section 5: Module - Development & Web ---
gcom() { git add . && git commit -m "$1"; }
lazyg() { git add . && git commit -m "$1" && git push; }

# Safe Web Directory Navigation
alias web='[[ -d /var/www/html ]] && cd /var/www/html || echo "Error: /var/www/html not found."'

apacheconfig() {
    local paths=("/etc/httpd/conf/httpd.conf" "/etc/apache2/apache2.conf")
    for p in "${paths[@]}"; do
        [[ -f "$p" ]] && { $EDITOR "$p"; return; }
    done
    echo "Error: Apache config not found."
}

# --- Section 6: Module - File Utilities ---
alias cp='cp -iv --reflink=auto'
alias mv='mv -iv'
alias rm='trash -v'
alias mkdir='mkdir -p -v'
alias ls='eza --color=always --icons'
alias ll='eza -alh --icons'
alias tree='eza --tree --icons'
alias c='clear'
alias x='exit'

# Go up N directories
up() {
    local d=""
    local limit=${1:-1}
    for ((i=0; i<limit; i++)); do d="../$d"; done
    cd "$d"
}

# Safe copy and go
cpg() { cp "$1" "$2" && [[ -d "$2" ]] && cd "$2"; }
mvg() { mv "$1" "$2" && [[ -d "$2" ]] && cd "$2"; }
mkdirg() { mkdir -p "$1" && cd "$1"; }

# --- Section 7: Initializations ---
[[ -x "$(command -v starship)" ]] && eval "$(starship init bash)"
[[ -x "$(command -v zoxide)" ]] && eval "$(zoxide init bash)"
