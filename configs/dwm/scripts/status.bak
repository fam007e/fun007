#!/usr/bin/env sh

LOGFILE="$HOME/.cache/dwm_status.log"

# Initialize
printf "$$" > ~/.cache/pidofbar
sec=0

# Update functions
update_cpu() {
  cpu=$(awk '{print $1}' /proc/loadavg)
}

update_memory() {
  memory=$(free -h | awk 'NR==2 {print $3}')
}

update_time() {
  time=$(TZ='Asia/Dhaka' date +"%I:%M %p %a %b %d, %Y")
}

update_weather() {
  weather=$(curl -s "https://wttr.in/dhaka?format=2" | awk '{gsub(/   /, " "); print}')
}

update_bat() {
  if [ -e /sys/class/power_supply/BAT0/status ]; then
    bat_status=$(< /sys/class/power_supply/BAT0/status)
    if [ -e /sys/class/power_supply/BAT0/capacity ]; then
      bat_capacity=$(< /sys/class/power_supply/BAT0/capacity)
      case $bat_capacity in
        100|9[0-9]|8[0-9]) bat_icon="" ;;
        7[0-9]|6[0-9]) bat_icon="" ;;
        5[0-9]|4[0-9]) bat_icon="" ;;
        3[0-9]|2[0-9]) bat_icon="" ;;
        1[0-9]|[0-9]) bat_icon="" ;;
      esac
      if [ "$bat_status" = "Charging" ]; then
        bat="🔌 $bat_icon $bat_capacity%"
      else
        bat="🔋 $bat_icon $bat_capacity%"
      fi
    else
      bat="Battery capacity not available"
    fi
  else
    bat="Battery status unavailable"
  fi
}

update_vol() {
  vol="奄 $(pactl list sinks | awk '/^Sink /{sink=$2} /State: RUNNING/{running_sink=sink} $1=="Volume:" && sink==running_sink {print $5; exit}' | tr -d '%')%"
}

update_backlight() {
  if [ -e /sys/class/backlight/intel_backlight/actual_brightness ]; then
    actual_brightness=$(cat /sys/class/backlight/intel_backlight/actual_brightness)
    max_brightness=$(cat /sys/class/backlight/intel_backlight/max_brightness)
    backlight="☀$((actual_brightness * 100 / max_brightness))%"
    echo "Actual brightness: $actual_brightness, Max brightness: $max_brightness, Calculated backlight: $backlight" >> $LOGFILE
  else
    backlight="Backlight not available"
    echo "Backlight not available" >> $LOGFILE
  fi
}

# Display function
display() {
  status=""
  [ -n "$cpu" ] && status+="CPU: $cpu "
  [ -n "$memory" ] && status+="Mem: $memory "
  [ -n "$weather" ] && status+="Weather: $weather "
  [ -n "$bat" ] && status+="Bat: $bat "
  [ -n "$backlight" ] && status+="BLight: $backlight "
  [ -n "$vol" ] && status+="Vol: $vol "
  [ -n "$time" ] && status+="$time"
  xsetroot -name "$status"
}

# Set up signal handlers
trap "update_vol; display" "RTMIN"
trap "update_backlight; display" "RTMIN+1"
trap "update_bat; display" "RTMIN+2"

# Initial updates
update_vol
update_backlight
update_bat
update_time
update_weather
update_cpu
update_memory

# Initial display
display

# Main loop
while true; do
  sleep 1
  sec=$((sec + 1))
  case $((sec % 60)) in
    0) 
      update_bat
      update_backlight
      ;;
    5|10|15|20|25|30|35|40|45|50|55)
      update_time
      update_cpu
      update_memory
      ;;
  esac

  # Update weather every 8 hours
  if [ $((sec % 3600)) -eq 0 ]; then
    update_weather
  fi

  update_vol
  display
done
